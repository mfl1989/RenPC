# 本番 SMTP 用の設定例
# 標準案として SendGrid SMTP を前提にしています。
# 他プロバイダを使う場合は MAIL_HOST / MAIL_PORT / 認証方式を読み替えてください。

MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_PROTOCOL=smtp
MAIL_USERNAME=apikey
MAIL_PASSWORD=replace-with-sendgrid-api-key
MAIL_SMTP_AUTH=true
MAIL_SMTP_SSL_ENABLE=false
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=false
MAIL_SMTP_CONNECTION_TIMEOUT_MS=5000
MAIL_SMTP_TIMEOUT_MS=10000
MAIL_SMTP_WRITE_TIMEOUT_MS=10000

NOTIFICATION_MAIL_ENABLED=true
NOTIFICATION_MAIL_FROM=no-reply@renpc.jp
NOTIFICATION_MAIL_FROM_NAME=RenPCカスタマーサポート
NOTIFICATION_MAIL_REPLY_TO=support@renpc.jp
CONTACT_INQUIRY_ADMIN_TO=ops@renpc.jp
NOTIFICATION_COMPANY_NAME=RenPC
NOTIFICATION_SUPPORT_DESK_NAME=RenPCカスタマーサポート
NOTIFICATION_SUPPORT_HOURS=平日 9:00〜18:00（土日祝日・年末年始を除く）
PUBLIC_BASE_URL=https://www.renpc.jp

# Office 365 を使う場合の例
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_PROTOCOL=smtp
# MAIL_USERNAME=no-reply@your-domain.com
# MAIL_PASSWORD=replace-with-mailbox-password-or-app-password
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_SSL_ENABLE=false
# MAIL_SMTP_STARTTLS_ENABLE=true
# MAIL_SMTP_STARTTLS_REQUIRED=true

# Google Workspace を使う場合の例
# アカウント認証で送る場合は、アプリパスワードまたは組織ポリシーに沿った認証情報が必要です。
# SMTP Relay を使う場合は MAIL_USERNAME / MAIL_PASSWORD / MAIL_SMTP_AUTH を運用に合わせて調整してください。
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_PROTOCOL=smtp
# MAIL_USERNAME=no-reply@your-domain.com
# MAIL_PASSWORD=replace-with-app-password
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_SSL_ENABLE=false
# MAIL_SMTP_STARTTLS_ENABLE=true
# MAIL_SMTP_STARTTLS_REQUIRED=true